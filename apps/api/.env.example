# ===========================================
# AUTH - better-auth (required)
# ===========================================
# Generate with: openssl rand -base64 32
# IMPORTANT: Use different secrets for dev and prod.
AUTH_SECRET=your-secret-key-min-32-chars-here

# Public origin of the API. In dev that's the API dev port; in prod the
# same origin that serves both /api/* and the SPA shell.
BETTER_AUTH_URL=http://localhost:8000

# ===========================================
# OAuth providers
# ===========================================
# Google: console.cloud.google.com -> APIs & Services -> Credentials
#   -> Create Credentials -> OAuth Client ID -> Web Application
# Authorized redirect URIs:
#   http://localhost:8000/api/auth/callback/google  (dev)
#   https://kasero.app/api/auth/callback/google     (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# Email (Resend)
# ===========================================
# 1. Create an account at resend.com
# 2. Add and verify the sending domain (SPF + DKIM + DMARC DNS records)
# 3. API Keys -> Create API Key (full access)
# 4. EMAIL_FROM must use a verified domain
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="Kasero <noreply@kasero.app>"

# ===========================================
# Cron - shared secret for /api/cron/* endpoints
# ===========================================
# Generate with: openssl rand -base64 32
# Set in Vercel: Project -> Settings -> Cron Jobs -> Authorization header.
CRON_SECRET=your-cron-secret

# ===========================================
# DATABASE - Turso (production only)
# ===========================================
# Used by the app in production and by `npm run db:push:prod`.
# In development, the API uses a local SQLite file (data/local.db) automatically.
# 1. Install CLI: brew install tursodatabase/tap/turso
# 2. Login:       turso auth login
# 3. Create DB:   turso db create pos
# 4. Get URL:     turso db show pos --url
# 5. Get token:   turso db tokens create pos
TURSO_DATABASE_URL=libsql://pos-yourname.turso.io
TURSO_AUTH_TOKEN=eyJ...your-prod-token

# ===========================================
# AI Features (optional)
# ===========================================
# OpenAI - product identification (GPT-4o Mini Vision)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# fal.ai - emoji icon generation, background removal
# https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key

# IMPORTANT: configure spending alerts on BOTH provider dashboards. The
# app enforces three layers of rate limiting (per-minute per-user, per-day
# per-user, global per-day) but those are insurance, not guarantees against
# misconfiguration. Recommended:
#   - OpenAI: Settings -> Billing -> Usage limits (soft + hard caps)
#   - fal.ai: Dashboard -> Billing -> Budget alerts (email at $X/day)

# ===========================================
# Distributed rate limiting (optional, production)
# ===========================================
# When both vars are set, checkRateLimit() delegates to Upstash Redis so
# counters are shared across Lambda instances. Without them, the in-memory
# fallback runs (fine for local dev, NOT appropriate for multi-instance prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===========================================
# i18n translate script (dev-only)
# ===========================================
# Used only by `npm run i18n:translate` to generate non-English message
# bundles via the Claude API. Local-only; never read at runtime and never
# needed in Vercel env vars.
# https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# Local dev port
# ===========================================
# The dev script reads API_PORT (defaults to 8000) for the --port flag.
# A custom name is used because some shells export PORT=<other> for unrelated
# projects, and Next.js's PORT env would override .env.local silently.
# Must match the host in apps/web/.env.local's VITE_API_PROXY_TARGET.
#
# Also set PORT to the same value so server-side code that reads
# process.env.PORT (e.g. start:local) stays in sync with the dev bind.
API_PORT=8000
PORT=8000

# ===========================================
# STORAGE - no extra config needed
# ===========================================
# Development: files saved to public/media/ (gitignored)
# Production:  icons stored as base64 in Turso database

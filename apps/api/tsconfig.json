{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"],
      "@kasero/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/shared/src/types/*.d.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}

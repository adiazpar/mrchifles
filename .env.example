# ===========================================
# AUTH - JWT Secret
# ===========================================
# Generate with: openssl rand -base64 32
# IMPORTANT: Use different secrets for dev and prod!
AUTH_SECRET=your-secret-key-min-32-chars-here

# ===========================================
# DATABASE - Turso (Production)
# ===========================================
# Used by the app in production and by `npm run db:push:prod`
# In development, the app uses a local SQLite file (data/local.db) automatically.
# 1. Install CLI: brew install tursodatabase/tap/turso
# 2. Login: turso auth login
# 3. Create DB: turso db create pos
# 4. Get URL: turso db show pos --url
# 5. Get token: turso db tokens create pos
TURSO_DATABASE_URL=libsql://pos-yourname.turso.io
TURSO_AUTH_TOKEN=eyJ...your-prod-token

# ===========================================
# AI Features (optional)
# ===========================================
# OpenAI - Product identification (GPT-4o Mini Vision)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# fal.ai - Emoji icon generation
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key

# IMPORTANT: Configure spending alerts on BOTH provider dashboards.
# The app enforces three layers of rate limiting (per-minute per-user,
# per-day per-user, global per-day) but those are insurance, not
# guarantees against a misconfiguration. Recommended:
#   - OpenAI: Settings -> Billing -> Usage limits (soft alert at $X/day,
#     hard limit at $Y/day)
#   - fal.ai: Dashboard -> Billing -> Budget alerts (email at $X/day)
# Pick a budget that is at least the global daily call cap times the
# per-call cost (RateLimits.aiGlobalDaily defaults to 10000 calls/day;
# at generate-icon's $0.04/call that is up to $400/day worst-case).

# ===========================================
# i18n Translate Script (dev-only)
# ===========================================
# Used only by `npm run i18n:translate` to generate non-English messages
# from src/i18n/messages/en-US.json via the Claude API. Local-only; never
# referenced by the app at runtime and never needed in Vercel env vars.
# Get from: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# STORAGE - No additional config needed!
# ===========================================
# In development: Files saved to public/media/ (gitignored)
# In production: Icons stored as base64 in Turso database

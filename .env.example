# ===========================================
# Local development ports (reference only)
# ===========================================
# This file documents the port layout for the monorepo.
# Actual values live in the per-app .env.local files:
#
#   apps/api/.env.local   API_PORT=<api port>   (also PORT=<same value>)
#   apps/web/.env.local   VITE_WEB_PORT=<web port>
#                         VITE_API_PROXY_TARGET=https://localhost:<api port>
#
# The web Vite dev server proxies /api/* to the API at VITE_API_PROXY_TARGET,
# so API_PORT here and the host in VITE_API_PROXY_TARGET must match.

# API server (Next.js) — apps/api dev script reads API_PORT (default 8000).
# A custom var is used because shells in this environment may export PORT for
# other projects, which would silently override Next.js's .env.local PORT.
API_PORT=8000

# Web dev server (Vite) — set in apps/web/.env.local as VITE_WEB_PORT=<n>.
WEB_PORT=3000

# ===========================================
# Application secrets and integrations
# ===========================================
# All app-level secrets (AUTH_SECRET, TURSO_*, OPENAI_API_KEY, FAL_KEY,
# ANTHROPIC_API_KEY, UPSTASH_*) live in apps/api/.env.local in development
# and in Vercel project env vars in production. See apps/api/.env.example
# for the full template.

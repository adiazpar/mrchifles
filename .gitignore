# Dependencies
node_modules/

# Local dev database
data/

# Next.js
.next/
out/
# next-env.d.ts is auto-generated by `next dev` / `next build` and flips its
# routes.d.ts import path depending on which mode ran last — committing it
# just creates churn. Next.js regenerates it locally as needed.
next-env.d.ts

# Environment.
#
# This project keeps secrets in two places only:
#   - apps/<api|web>/.env.local — local development
#   - Vercel project env vars   — preview + production
#
# There are NO .env.production / .env.staging files anywhere. For prod
# migrations or scripts run from a developer machine, either export the
# vars inline (`TURSO_DATABASE_URL=... TURSO_AUTH_TOKEN=... npm run ...`)
# or pull them down on demand with `vercel env pull .env.local`.
#
# The broad pattern below is defense-in-depth: if anything (a future tool,
# a tutorial copy-paste, vercel env pull's default output name) ever lands
# a file named `.env.production` / `.env.staging` / etc. on disk, it won't
# accidentally get committed. The .env*.example template files stay tracked.
.env*
!.env.example
!.env*.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
**/.DS_Store
Thumbs.db
*.log


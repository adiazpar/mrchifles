{
  "name": "kasero",
  "version": "0.1.1",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "npm run build --workspace=packages/shared --if-present && npm run build:api && npm run build:web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web --if-present",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:run": "npm run test:run --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
